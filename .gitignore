# ============================================================
# Kounhany Wallet — .gitignore
# ============================================================

# ─── ENVIRONNEMENT & SECRETS ──────────────────────────────────
backend/.env
frontend/.env.local
frontend/.env.production
docker/dolibarr/conf.php
*.env
.env.*
!.env.example

# ─── NODE MODULES ─────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/
**/node_modules/

# ─── NEXT.JS ──────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/
frontend/.swc/

# ─── LOGS ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
backend/logs/

# ─── DOCKER VOLUMES & DATA ────────────────────────────────────
docker/postgres/data/
docker/redis/data/
docker/blnk/data/
docker/authentik/media/
docker/authentik/certs/
docker/dolibarr/documents/
postgres-data/
redis-data/

# ─── BACKUPS ──────────────────────────────────────────────────
*.sql.gz
backup_*.sql
backups/

# ─── TESTS & COVERAGE ─────────────────────────────────────────
backend/coverage/
frontend/coverage/
.nyc_output/

# ─── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── MISC ─────────────────────────────────────────────────────
*.pem
*.key
*.cert
dist/
tmp/
.tmp/

docker-compose.dev.yml

/docs
next.config.js