│       ├── TransactionFilters.jsx
│       └── TransactionDetailDialog.jsx
├── lib/
│   ├── api.js                  Fonctions API centralisées
│   ├── auth.js                 Auth service (login/logout)
│   └── alerts-context.js       Contexte global des alertes
└── theme/
    └── theme.js                Thème MUI (#FAC345, #212529)
```

